# ==============================================
# PROJECT PATHS & CONFIGURATION
# Copy this file to .env and adjust the paths
# ==============================================

# --- Animated Drawings Library Paths ---
# Path to the AnimatedDrawings examples directory
BASE_DIR=/path/to/external/AnimatedDrawings/examples
# Path to the custom MVC config directory
MVC_DIR=/path/to/external/AnimatedDrawings/examples/config/mvc/custom

# --- Rendering & Window Settings ---
# Set True if using software rendering (useful for headless servers)
USE_MESA=True
WINDOW_WIDTH=512
WINDOW_HEIGHT=512

# --- Camera Settings ---
CAMERA_POS=0.1,1.3,2.7
CAMERA_FWD=0.1,0.5,2.0

# --- MMPose Configuration ---
# Path to the MMPose model config file
POSE_MODEL_CFG_PATH=/path/to/external/mmpose_install/config.py
# Path to the trained checkpoint (.pth)
POSE_MODEL_CKPT_PATH=/path/to/external/mmpose_install/best_AP_epoch_72.pth

# --- Game Configuration ---
# Path to your game logic configuration yaml
GAME_CONFIG_PATH=./src/configs/game_cfg.yaml

# --- Segment Anything Model (SAM) ---
# Path to the SAM checkpoint weights
SAM_CHECKPOINT_PATH=/path/to/external/checkpoints/sam_vit_h_4b8939.pth

# --- Assets ---
# Path to the character body images folder
BODY_FOLDER_PATH=./src/configs/characters/cartoon_body

# ---API KEY ---
GOOGLE_API_KEY=